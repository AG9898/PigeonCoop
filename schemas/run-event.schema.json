{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "run-event.schema.json",
  "title": "RunEvent",
  "description": "Immutable event emitted during workflow execution. See EVENT_SCHEMA.md.",
  "type": "object",
  "required": ["event_id", "run_id", "workflow_id", "event_type", "timestamp", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "run_id": { "type": "string", "format": "uuid" },
    "workflow_id": { "type": "string", "format": "uuid" },
    "node_id": { "type": "string", "format": "uuid" },
    "event_type": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "payload": { "type": "object" },
    "causation_id": { "type": "string", "format": "uuid" },
    "correlation_id": { "type": "string", "format": "uuid" }
  }
}
