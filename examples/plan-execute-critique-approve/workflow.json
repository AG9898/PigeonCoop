{
  "workflow_id": "00000000-0000-0000-0000-000000000001",
  "name": "Plan → Execute Tool → Critique → Approve",
  "version": 1,
  "metadata": {
    "description": "Canonical v1 demo workflow. See ARCHITECTURE.md §7 (canonical first demo).",
